# Copy this file to .env and fill in your values.
# .env is loaded automatically by bot.py at startup.
# Actual environment variables always take precedence over values here.

DISCORD_TOKEN=your-bot-token-here
DISCORD_GUILD_ID=your-guild-id-here
GOOGLE_API_KEY=your-google-api-key-here
GOOGLE_SHEET_KEY=google-sheet-key-here

LOG_LEVEL=DEBUG

# Optional — defaults to 8080
DM_PANEL_PORT=8080

# Discord integration tests (tests/discord_integration/)
# Channel must exist in your guild; bot must have Send/Read/Manage Messages there.
# The bot will post and delete messages in this channel during test runs.
DISCORD_TEST_CHANNEL_ID=your-test-channel-id-here
# Your own Discord user ID — used as the DM in test sessions.
DISCORD_TEST_DM_USER_ID=your-user-id-here
